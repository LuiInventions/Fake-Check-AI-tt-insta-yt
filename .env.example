# --- APP CONFIG ---
APP_NAME=FakeCheck
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change_this_to_a_random_secret_string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# --- DATABASE & CACHE ---
# For local docker use redis:6379, for local python use localhost:6379
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=changeme
DATABASE_URL=sqlite+aiosqlite:////app/data/db/fakecheck.db

# --- API KEYS ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Required for News search & Instagram extraction via RapidAPI
# Services to enable on RapidAPI: 
# 1. News API (news-api14.p.rapidapi.com)
# 2. Instagram Looter (instagram-looter2.p.rapidapi.com)
RAPIDAPI_KEY=your_rapidapi_key_here

# Optional: Sightengine for AI detection (if empty, some features might skip)
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# --- TELEGRAM BOT ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# If true, the bot will use long polling instead of webhooks (recommended for local setup)
USE_POLLING=true
# Only needed if USE_POLLING=false
TELEGRAM_WEBHOOK_URL=

# --- ADMIN CREDENTIALS ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456

# --- FILE STORAGE ---
UPLOAD_DIR=/app/data/videos
FRAMES_DIR=/app/data/frames
